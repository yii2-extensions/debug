{
  "name": "@yii2-extensions/debug-assets",
  "private": true,
  "type": "module",
  "description": "Build pipeline for the yii2-extensions/debug client-side assets.",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "format": "prettier --write 'resources/src/**/*.js' 'vite.config.js' 'package.json'",
    "format:check": "prettier --check 'resources/src/**/*.js' 'vite.config.js' 'package.json'",
    "lint:css": "stylelint --config .github/linters/.stylelintrc.json --config-basedir . 'resources/src/styles/*.css'",
    "lint:css:fix": "stylelint --config .github/linters/.stylelintrc.json --config-basedir . --fix 'resources/src/styles/*.css'",
    "lint:js": "eslint --config .github/linters/eslint.config.mjs resources/src",
    "lint:js:fix": "eslint --config .github/linters/eslint.config.mjs --fix resources/src"
  },
  "engines": {
    "node": ">=20.10"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.10.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.0"
  }
}
